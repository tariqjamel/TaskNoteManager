<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ToDoDemo" parent="Theme.Material3.DayNight.NoActionBar">
<!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryVariant">@color/md_theme_dark_primary</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_dark_onPrimary</item>
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_theme_dark_secondary</item>
        <item name="colorOutline">@color/md_theme_dark_outline</item>
        <item name="colorSurface">@color/md_theme_dark_surface</item>
        <item name="colorOnBackground">@color/md_theme_dark_onBackground</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
    </style>

    <style name="SplashScreenTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryVariant">@color/blue</item>
        <item name="android:statusBarColor">@color/blue</item>
    </style>

    <style name="Theme.ToDoDemo" parent="Base.Theme.ToDoDemo" />
</resources>